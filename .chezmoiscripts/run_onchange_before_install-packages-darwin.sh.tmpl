{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

brew bundle --file=/dev/stdin <<EOF
brew "chezmoi"
brew "fzf"
brew "keychain"
brew "mole"
brew "neovim"
brew "tree"
brew "tealdeer"
EOF

if [ "$1" == "full" ]
then
  brew bundle --file=/dev/stdin <<EOF
  cask "ghostty"
  cask "nikitabobko/tap/aerospace"
  cask "proton-drive"
  cask "proton-pass"
  cask "protonvpn"
EOF
fi

{{ end -}}
